%
% Encoding mode bit sequences
%

% M1 N5: 12345 (no mode indicator in M1)
(12345) (version=M1 debugbitseqs) 3 [
    (101)         % Char count: 5
    (0001111011)  % 123
    (0101101)     % 45
] bitseqs_tmpl

% M2 A2: A1 (1-bit mode indicator)
(A1) (version=M2 eclevel=L fixedeclevel debugbitseqs) 4 [
    (1)            % A mode
    (010)          % Char count: 2
    (00111000011)  % A1: 10*45+1 = 451
] bitseqs_tmpl

% M3 B5: Hello (2-bit mode indicator)
(Hello) (version=M3 eclevel=L fixedeclevel debugbitseqs) 5 [
    (10)        % B mode
