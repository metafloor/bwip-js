%
% Error tests
%

% Empty data
() (dontdraw) /bwipp.qrcodeEmptyData er_tmpl

% Invalid version (valid: M1-M4)
(TEST) (version=M0 dontdraw) /bwipp.qrcodeInvalidMicroVersion er_tmpl
(TEST) (version=M5 dontdraw) /bwipp.qrcodeInvalidMicroVersion er_tmpl

% Invalid mask (valid: 0-3)
(TEST) (version=M2 mask=5 dontdraw) /bwipp.qrcodeBadMask er_tmpl

% Option edges
(TEST) (version=99 dontdraw) /bwipp.qrcodeInvalidMicroVersion er_tmpl
end
} bind def
