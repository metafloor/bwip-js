/runtest_microqrcode {
20 dict begin
% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

% ISO/IEC 18004:2015


%%/microqrcode dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    3 1 roll { _arg0_ _arg1_ microqrcode /pixs get }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    isEqual
} def

/er_tmpl {
    3 1 roll { _arg0_ _arg1_ microqrcode /pixs get }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def

/_bitseqsEqual {
    % Stack: errorname errorinfo [vg (expected)]
    aload pop 3 1 roll get
    ne {/testError pstack quit} if
    pop
} bind def
/bitseqsEqual { //_bitseqsEqual //_doTest exec } def

% data opts vg [(seg1) (seg2) ...] bitseqs_tmpl
/bitseqs_tmpl {
    exch 4 1 roll                         % vg data opts [parts]
    0 1 index {length add} forall string  % cs = concat(parts)
    0 3 -1 roll { 3 copy putinterval length add } forall pop
    4 -1 roll exch 2 array astore         % data opts [vg cs]
    3 1 roll { _arg0_ _arg1_ microqrcode }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch bitseqsEqual
} def


% Codewords pipeline check
{  % M1 N5: 12345
    (12345) (version=M1 debugcws) microqrcode
} [163 218 208] debugIsEqual


% numBs calculation

% B1 not in Kanji 1st byte range
(^128) (parse fixedeclevel debugbitseqs) 5 [
    (10)          % B mode
    (0001)        % Char count: 1
    (10000000)    % 0x80
] bitseqs_tmpl

% B1 in Kanji 1st byte range
(^129) (parse fixedeclevel debugbitseqs) 5 [
    (10)          % B mode
    (0001)        % Char count: 1
    (10000001)    % 0x81
] bitseqs_tmpl


% Encodation examples

% A11, 11 alphanumerics max for M3-M (Table 7)
(ABCDEFGHIJK) (version=M3 eclevel=M fixedeclevel debugbitseqs) 5 [
    (01)             % A mode
    (1011)           % Char count: 11
    (00111001101)    % AB: 10*45+11 = 461
    (01000101001)    % CD: 12*45+13 = 553
    (01010000101)    % EF: 14*45+15 = 645
    (01011100001)    % GH: 16*45+17 = 737
    (01100111101)    % IJ: 18*45+19 = 829
    (010100)         % K: 20
] bitseqs_tmpl

% B15, 15 bytes max for M4-L (Table 7)
(???????????????) (version=M4 eclevel=L fixedeclevel debugbitseqs) 6 [
    (010)         % B mode
    (01111)       % Char count: 15
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
] bitseqs_tmpl

% K9 (点茗や×3), 9 Kanji max for M4-L (Table 7); note ^226^147 (0xE293) also valid Shift JIS
(^147^095^228^170^130^226^147^095^228^170^130^226^147^095^228^170^130^226) (parse version=M4 eclevel=L fixedeclevel debugbitseqs) 6 [
    (011)              % K mode
    (1001)             % Char count: 9
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
] bitseqs_tmpl

% B12 (?点茗や点茗?), modeBKbeforeB M4 change 5 -> 6, previously B1 K5 B1 (same msgbits length)
(?^147^095^228^170^130^226^147^095^228^170?) (parse version=M4 eclevel=L fixedeclevel debugbitseqs) 6 [
    (010)         % B mode
    (01100)       % Char count: 12
    (00111111)    % 0x3F '?'
    (10010011)    % 0x93
    (01011111)    % 0x5F
    (11100100)    % 0xE4
    (10101010)    % 0xAA
    (10000010)    % 0x82
    (11100010)    % 0xE2
    (10010011)    % 0x93
    (01011111)    % 0x5F
    (11100100)    % 0xE4
    (10101010)    % 0xAA
    (00111111)    % 0x3F '?'
] bitseqs_tmpl

% B1 K3 N1 (?点茗や1), modeBKbeforeN M3 change 5 -> 3, previously B8 (longer msgbits length)
(?^147^095^228^170^130^2261) (parse version=M3 eclevel=L fixedeclevel debugbitseqs) 5 [
    (10)               % B mode
    (0001)             % Char count: 1
    (00111111)         % 0x3F '?'
    (11)               % K mode
    (011)              % Char count: 3
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
    (00)               % N mode
    (00001)            % Char count: 1
    (0001)             % 1
] bitseqs_tmpl

% B1 K4 N1 (?点茗や点1), modeBKbeforeN M3 change 5 -> 3, previously not encodable (msgbits too long)
(?^147^095^228^170^130^226^147^0951) (parse version=M3 eclevel=L fixedeclevel debugbitseqs) 5 [
    (10)               % B mode
    (0001)             % Char count: 1
    (00111111)         % 0x3F '?'
    (11)               % K mode
    (100)              % Char count: 4
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
    (0110110011111)    % 点: Kanji 3487
    (00)               % N mode
    (00001)            % Char count: 1
    (0001)             % 1
] bitseqs_tmpl

% B1 K5 N1 (?点茗や点茗1), modeBKbeforeN M4 change 6 -> 5, previously B12 (longer msgbits length)
(?^147^095^228^170^130^226^147^095^228^1701) (parse version=M4 eclevel=L fixedeclevel debugbitseqs) 6 [
    (010)              % B mode
    (00001)            % Char count: 1
    (00111111)         % 0x3F '?'
    (011)              % K mode
    (0101)             % Char count: 5
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0000101100010)    % や: Kanji 354
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (000)              % N mode
    (000001)           % Char count: 1
    (0001)             % 1
] bitseqs_tmpl

% A3 K1 (ABC点), new initial mode A before K reusing modeBAbeforeE array, previously B5 (longer msgbits length)
(ABC^147^095) (parse version=M3 eclevel=L fixedeclevel debugbitseqs) 5 [
    (01)               % A mode
    (0011)             % Char count: 3
    (00111001101)      % AB: 10*45+11 = 461
    (001100)           % C: 12
    (11)               % K mode
    (001)              % Char count: 1
    (0110110011111)    % 点: Kanji 3487
] bitseqs_tmpl

