    (1000)             % Kanji mode
    (00000100)         % Char count: 4 (8-bit)
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
] bitseqs_tmpl

