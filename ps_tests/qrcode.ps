%
% Sequence building tests - exercise same-mode path which extends seq array
% These patterns have letters followed by digits, which triggers same-mode
% iterations as digits are processed one at a time in alphanumeric mode
%

% A10 (A1B2C3D4E5), alternating alpha-digit pattern
(A1B2C3D4E5) (fixedeclevel debugbitseqs) 0 [
    (0010)             % Alphanumeric mode
    (000001010)        % Char count: 10 (9-bit)
    (00111000011)      % A1: 10*45+1=451
    (00111110001)      % B2: 11*45+2=497
    (01000011111)      % C3: 12*45+3=543
    (01001001101)      % D4: 13*45+4=589
    (01001111011)      % E5: 14*45+5=635
] bitseqs_tmpl

% A10 (ABCDE12345), 5 letters then 5 digits - tests same-mode with short run
(ABCDE12345) (fixedeclevel debugbitseqs) 0 [
    (0010)             % Alphanumeric mode
    (000001010)        % Char count: 10 (9-bit)
    (00111001101)      % AB: 10*45+11=461
    (01000101001)      % CD: 12*45+13=553
    (01001110111)      % E1: 14*45+1=631
    (00001011101)      % 23: 2*45+3=93
    (00010111001)      % 45: 4*45+5=185
] bitseqs_tmpl

% A5+N50 (ABCDE + 50 digits), 5 letters then 50 digits - stress test same-mode path
(ABCDE12345678901234567890123456789012345678901234567890) (fixedeclevel debugbitseqs) 0 [
    (0010)             % Alphanumeric mode
    (000000101)        % Char count: 5 (9-bit)
    (00111001101)      % AB: 10*45+11=461
    (01000101001)      % CD: 12*45+13=553
    (001110)           % E: 14
    (0001)             % Numeric mode
    (0000110010)       % Char count: 50 (10-bit)
    (0001111011)       % 123
    (0111001000)       % 456
    (1100010101)       % 789
    (0000001100)       % 012
    (0101011001)       % 345
    (1010100110)       % 678
    (1110000101)       % 901
    (0011101010)       % 234
    (1000110111)       % 567
    (1101111010)       % 890
    (0001111011)       % 123
    (0111001000)       % 456
    (1100010101)       % 789
    (0000001100)       % 012
    (0101011001)       % 345
    (1010100110)       % 678
    (1011010)          % 90
] bitseqs_tmpl


%
% Error tests
%

% Empty data
() (dontdraw) /bwipp.qrcodeEmptyData er_tmpl

% Input too long
30001 string (dontdraw) /bwipp.qrcodeinputTooLong er_tmpl

% Invalid format
(TEST) (format=invalid dontdraw) /bwipp.qrcodeInvalidFormat er_tmpl

% Invalid eclevel
(TEST) (eclevel=X dontdraw) /bwipp.qrcodeInvalidEClevel er_tmpl

% Invalid version for full QR Code (valid: 1-40)
(TEST) (version=41 dontdraw) /bwipp.qrcodeInvalidFullVersion er_tmpl
(TEST) (version=99 dontdraw) /bwipp.qrcodeInvalidFullVersion er_tmpl

% Invalid mask (valid: 0-7)
(TEST) (mask=9 dontdraw) /bwipp.qrcodeBadMask er_tmpl

% Data exceeds maximum symbol capacity
{ 7100 string 0 1 7099 { 1 index exch 49 put } for (dontdraw) qrcode } /bwipp.qrcodeNoValidSymbol isError

% Option edges
(TEST) (eclevel=Z dontdraw) /bwipp.qrcodeInvalidEClevel er_tmpl
(TEST) (version=0 dontdraw) /bwipp.qrcodeNoValidSymbol er_tmpl
(TEST) (version=999 dontdraw) /bwipp.qrcodeInvalidFullVersion er_tmpl
(TEST) (mask=-2 dontdraw) /bwipp.qrcodeBadMask er_tmpl
{ (TEST) (mask=8 dontdraw) qrcode pop true } true isEqual
(TEST) (mask=99 dontdraw) /bwipp.qrcodeBadMask er_tmpl
(TEST) (version=M1 dontdraw) /bwipp.qrcodeNoValidSymbol er_tmpl
(TEST) (version=M5 dontdraw) /bwipp.qrcodeInvalidMicroVersion er_tmpl
{ (TEST) (version=R7x43 dontdraw) qrcode pop true } true isEqual
(TEST) (format=rmqr dontdraw) /bwipp.qrcodeRMQRwithoutVersion er_tmpl
(TEST) (format=rmqr version=R99x99 dontdraw) /bwipp.qrcodeInvalidRMQRversion er_tmpl
(TEST) (format=rmqr version=R7x43 mask=0 dontdraw) /bwipp.qrcodeRMQRmask er_tmpl

% Parse edges
{ (^) (parse dontdraw) qrcode pop true } true isEqual
{ (^^) (parse dontdraw) qrcode pop true } true isEqual
{ (^000) (parse dontdraw) qrcode pop true } true isEqual
{ (^255) (parse dontdraw) qrcode pop true } true isEqual
(^256) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
(^999) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
{ (^NUL) (parse dontdraw) qrcode pop true } true isEqual
{ (A^) (parse dontdraw) qrcode pop true } true isEqual
{ (^1) (parse dontdraw) qrcode pop true } true isEqual
{ (^12) (parse dontdraw) qrcode pop true } true isEqual

% parsefnc edges
{ (^FNC1) (parse parsefnc dontdraw) qrcode pop true } true isEqual
{ (^ECI000000) (parse parsefnc dontdraw) qrcode pop true } true isEqual
{ (^ECI999999) (parse parsefnc dontdraw) qrcode pop true } true isEqual
(^ECI) (parse parsefnc dontdraw) /bwipp.truncatedECI er_tmpl
(^ECI1) (parse parsefnc dontdraw) /bwipp.truncatedECI er_tmpl

end
} bind def
