/runtest_qrcode {
20 dict begin
% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

% ISO/IEC 18004:2015


%%/qrcode dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    3 1 roll { _arg0_ _arg1_ qrcode /pixs get }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    isEqual
} def

/er_tmpl {
    3 1 roll { _arg0_ _arg1_ qrcode /pixs get }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def

/_bitseqsEqual {
    % Stack: errorname errorinfo [vg (expected)]
    aload pop 3 1 roll get
    ne {/testError pstack quit} if
    pop
} bind def
/bitseqsEqual { //_bitseqsEqual //_doTest exec } def

% data opts vg [(seg1) (seg2) ...] bitseqs_tmpl
/bitseqs_tmpl {
    exch 4 1 roll                         % vg data opts [parts]
    0 1 index {length add} forall string  % cs = concat(parts)
    0 3 -1 roll { 3 copy putinterval length add } forall pop
    4 -1 roll exch 2 array astore         % data opts [vg cs]
    3 1 roll { _arg0_ _arg1_ qrcode }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch bitseqsEqual
} def


% Codewords check
{
    (TESTING) (fixedeclevel debugcws) qrcode
} [32 61 39 161 45 5 0 236 17 236 17 236 17 236 17 236] debugIsEqual

% ECC check
{
    (TESTING) (fixedeclevel debugecc) qrcode
} [32 61 39 161 45 5 0 236 17 236 17 236 17 236 17 236 124 49 125 89 133 221 9 38 29 92] debugIsEqual

% K4 (点茗点茗); 7.4.6 examples 点 0x935F (^147^095) and 茗 0xE4AA (^228^170); 4 Kanji max for version 1-H (Table 7)
