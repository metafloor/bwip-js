% Text compaction: Upper submode

(A) (debugbits) [
    (00010)    % A
] bits_tmpl

% HELLO in upper
(HELLO) (debugbits) [
    (01001)    % H
    (00110)    % E
    (01101)    % L
    (01101)    % L
    (10000)    % O
] bits_tmpl

% Text compaction: Lower submode
(hello) (debugbits) [
    (11100)    % L/L
    (01001)    % h
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
] bits_tmpl

% Text compaction: Mixed submode
(0123) (debugbits) [
    (11110)    % D/L
    (0010)     % 0
    (0011)     % 1
    (0100)     % 2
    (0101)     % 3
] bits_tmpl

% Text compaction: mode transitions

% Upper to lower
(ABCabc) (debugbits) [
    (00010)    % A
    (00011)    % B
    (00100)    % C
    (11100)    % L/L
    (00010)    % a
    (00011)    % b
    (00100)    % c
] bits_tmpl

% Lower to upper (via D/L U/L)
(abcABC) (debugbits) [
    (11100)    % L/L
    (00010)    % a
    (00011)    % b
    (00100)    % c
    (11110)    % D/L
    (1110)     % U/L
    (00010)    % A
    (00011)    % B
    (00100)    % C
] bits_tmpl

% Upper to mixed via digit
(ABC123) (debugbits) [
    (00010)    % A
    (00011)    % B
    (00100)    % C
    (11110)    % D/L
    (0011)     % 1
    (0100)     % 2
    (0101)     % 3
] bits_tmpl

% Punctuation encoding: ". " compression
(A. B) (debugbits) [
    (00010)    % A
    (00000)    % P/S
    (00011)    % .SP
    (00011)    % B
] bits_tmpl

% Punctuation shift for "!"
(Hello!) (debugbits) [
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
    (00000)    % P/S
    (00110)    % !
] bits_tmpl

% Byte compaction: 6 bytes
{
    /bdata 6 string def 0 1 5 {bdata exch 128 put} for
    bdata (debugbits) azteccode
} (1111100110100000001000000010000000100000001000000010000000) bitsEqual

% Byte compaction: 1 byte
{
    /bdata 1 string def bdata 0 255 put
    bdata (debugbits) azteccode
} (111110000111111111) bitsEqual

% Mixed text and bytes: "Hi" + 0x80 0x81 + "ABCD"
{
    /mdata 8 string def
    mdata 0 72 put mdata 1 105 put mdata 2 128 put mdata 3 129 put
    mdata 4 65 put mdata 5 66 put mdata 6 67 put mdata 7 68 put
    mdata (debugbits) azteccode
} (01001111110001101101001100000001000000100010000110010000101) bitsEqual

% Format options: compact
(Hello) (format=compact debugbits) [
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
] bits_tmpl

% Format options: full
(Hello World) (format=full debugbits) [
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
    (00001)    % SP
    (11100)    % U/S
    (11000)    % W
    (10000)    % o
    (10011)    % r
    (01101)    % l
    (00101)    % d
] bits_tmpl

% EC level: 50%
(Hello) (eclevel=50 debugbits) [
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
] bits_tmpl

% Reader initialisation
(Hello) (format=compact readerinit debugbits) [
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
] bits_tmpl

% ECI 3
(^ECI000003Hello) (parsefnc debugbits) [
    (00000)      % P/S
    (00000)      % Flg
    (0010101)    % ECI 3
    (01001)      % H
    (11100)      % L/L
    (00110)      % e
    (01101)      % l
    (01101)      % l
    (10000)      % o
] bits_tmpl

% ECI 900
(^ECI000900Hello) (parsefnc debugbits) [
    (00000)              % P/S
    (00000)              % Flg
    (011101100100010)    % ECI 900
    (01001)              % H
    (11100)              % L/L
    (00110)              % e
    (01101)              % l
    (01101)              % l
    (10000)              % o
] bits_tmpl

% FNC1
(^FNC1Hello) (parsefnc debugbits) [
    (00000)    % P/S
    (00000)    % Flg
    (000)      % FNC1
    (01001)    % H
    (11100)    % L/L
    (00110)    % e
    (01101)    % l
    (01101)    % l
    (10000)    % o
] bits_tmpl

% Parse mode - null byte
(^000) (parse debugbits) [
    (11111)       % B/S
    (00001)       % len 1
    (00000000)    % 0x00
] bits_tmpl

% Raw mode
(101010) (raw debugbits) [
    (101010)
] bits_tmpl


% Figures

% Figure 1 (left)
(123456789012) (debugbits) [
    (11110)    % D/L
    (0011)     % 1
    (0100)     % 2
    (0101)     % 3
    (0110)     % 4
    (0111)     % 5
    (1000)     % 6
    (1001)     % 7
    (1010)     % 8
    (1011)     % 9
    (0010)     % 0
    (0011)     % 1
    (0100)     % 2
] bits_tmpl

% Figure G.2
(Code 2D!) (debugbits) [
    (00100)    % C
    (11100)    % L/L
    (10000)    % o
    (00101)    % d
    (00110)    % e
    (11110)    % D/L
    (0001)     % SP
    (0100)     % 2
    (1111)     % U/S
    (00101)    % D
    (0000)     % P/S
    (00110)    % !
] bits_tmpl

{
    % Figure 1 (right), same
    (Aztec Code is a public domain 2D matrix barcode symbology of nominally square symbols built on a square grid with a distinctive square bullseye pattern at their center.) (debugcws) azteccode
} [23 55 83 16 60 36 10 96 170 129 16 99 97 181 68 9 96 225 41 254 10 113 120 23 10 179 86 66 49 76 144 41 131 77 56 112 108 17 160 192 225 124 28 167 137 173 208 105 43 10 102 13 52 225 193 180 8 236 166 212 48 120 68 26 74 194 153 130 137 168 161 194 170 144 136 37 85 42 167 146 170 185 131 73 88 83 48 71 102 182 134 209 131 17 86 166 155 194 42 134 169 50 166 18 25 245 52 253 191] debugIsEqual

