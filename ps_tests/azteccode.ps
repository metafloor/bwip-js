% Binary before punct compression had a problem

<6A 99 3A 20 53> (debugbits) [  % "j<99>: S": B/S for 3 non-text bytes, then U text
    (11111)       % B/S
    (00011)       % len 3
    (01101010)    % 0x6A
    (10011001)    % 0x99
    (00111010)    % 0x3A
    (00001)       % SP
    (10100)       % S
] bits_tmpl

(^153. ) (parse debugbits) [
    (11111)       % B/S
