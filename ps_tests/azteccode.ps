    (^013^010) (parse debugcws) azteccode
} [970 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 682 672 191] debugIsEqual


%
% Error tests
%

% Input too long
20001 string (dontdraw) /bwipp.azteccodeinputTooLong er_tmpl

% Empty data
() (dontdraw) /bwipp.aztecEmptyData er_tmpl

% Invalid eclevel (valid: 5-95)
(TEST) (eclevel=4 dontdraw) /bwipp.aztecInvalidEClevel er_tmpl
(TEST) (eclevel=96 dontdraw) /bwipp.aztecInvalidEClevel er_tmpl

% Invalid ecaddchars (valid: 3+)
(TEST) (ecaddchars=2 dontdraw) /bwipp.aztecInvalidECaddChars er_tmpl

% Invalid format (valid: full, compact, rune)
(TEST) (format=invalid dontdraw) /bwipp.aztecInvalidFormat er_tmpl

% Invalid layers (valid: 1-32 for full)
(TEST) (layers=0 dontdraw) /bwipp.aztecFullInvalidLayers er_tmpl
(TEST) (layers=33 dontdraw) /bwipp.aztecFullInvalidLayers er_tmpl

% Reader init invalid layers (valid: 1-22 for full)
(TEST) (layers=23 readerinit dontdraw) /bwipp.aztecFullInitInvalidLayers er_tmpl

% Data too long for symbol
(ABCDEFGHIJKLMNOPQRSTUVWXYZ) (layers=1 dontdraw) /bwipp.aztecNoValidSymbol er_tmpl

% Large binary input that requires segment splitting
{ 2100 string 0 1 2099 { 1 index exch 128 put } for (dontdraw) azteccode } /bwipp.aztecNoValidSymbol isError


%
% Coefficient cache tests (azteccode.cachelimit in global context)
%

% Large symbol with caching (default)
{
    (Aztec Code is a public domain 2D matrix barcode symbology) (debugcws) azteccode
} [23 55 83 16 60 36 10 96 170 129 16 99 97 181 68 9 96 225 41 254 10 113 120 23 10 179 86 66 49 76 144 41 131 77 56 112 108 17 175] debugIsEqual

% Cache disabled via global context - same result
%%uk.co.terryburton.bwipp.global_ctx /azteccode.cachelimit 0 put
{
    (Aztec Code is a public domain 2D matrix barcode symbology) (debugcws) azteccode
} [23 55 83 16 60 36 10 96 170 129 16 99 97 181 68 9 96 225 41 254 10 113 120 23 10 179 86 66 49 76 144 41 131 77 56 112 108 17 175] debugIsEqual
%%uk.co.terryburton.bwipp.global_ctx /azteccode.cachelimit undef  % Remove to restore default


% Option edges: layers
{ (TEST) (layers=-1 dontdraw) azteccode pop true } true isEqual

% Option edges: eclevel
(TEST) (eclevel=-1 dontdraw) /bwipp.aztecInvalidEClevel er_tmpl
(TEST) (eclevel=200 dontdraw) /bwipp.aztecInvalidEClevel er_tmpl

% Option edges: format
(TEST) (format=badval dontdraw) /bwipp.aztecInvalidFormat er_tmpl

% Option edges: compact layers (valid: 1-4)
(TEST) (format=compact layers=0 dontdraw) /bwipp.aztecCompactInvalidLayers er_tmpl
(TEST) (format=compact layers=5 dontdraw) /bwipp.aztecCompactInvalidLayers er_tmpl

% Option edges: compact readerinit layers (must be 1)
(TEST) (format=compact layers=2 readerinit dontdraw) /bwipp.aztecCompactInitInvalidLayers er_tmpl

% Option edges: rune layers (not allowed)
(255) (format=rune layers=1 dontdraw) /bwipp.aztecRuneInvalidLayers er_tmpl

% parsefnc edge cases
{ (^ECI000000) (parsefnc dontdraw) azteccode pop true } true isEqual
{ (^ECI999999) (parsefnc dontdraw) azteccode pop true } true isEqual
end
} bind def
