/runtest_azteccode {
20 dict begin
% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

% ISO/IEC 24778:2008


%%/azteccode dup /uk.co.terryburton.bwipp findresource cvx def

/_bitsEqual {
    % Stack: errorname errorinfo (expected)
    ne {/testError pstack quit} if
    pop
} bind def
/bitsEqual { //_bitsEqual //_doTest exec } def

% data opts [(seg1) (seg2) ...] bits_tmpl
/bits_tmpl {
    0 1 index {length add} forall string       % data opts [parts] cs
    0 3 -1 roll { 3 copy putinterval length add } forall pop  % data opts cs
    3 1 roll { _arg0_ _arg1_ azteccode }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch bitsEqual
} def

/er_tmpl {
    3 1 roll { _arg0_ _arg1_ azteccode }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def


% Punctuation-space combinations (PR #161)

(. ) (debugbits) [
    (00000)    % P/S
    (00011)    % .SP
] bits_tmpl

(^013^010) (parse debugbits) [
    (00000)    % P/S
    (00010)    % CRLF
] bits_tmpl

(. . . . . ) (debugbits) [
    (11101)    % M/L
    (11110)    % P/L
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
] bits_tmpl

(A. ) (debugbits) [          % Upper
    (00010)    % A
    (00000)    % P/S
    (00011)    % .SP
] bits_tmpl

(A^013^010) (parse debugbits) [  % Upper
    (00010)    % A
    (00000)    % P/S
    (00010)    % CRLF
] bits_tmpl

(A. . . . . ) (debugbits) [  % Upper
    (00010)    % A
    (11101)    % M/L
    (11110)    % P/L
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
    (00011)    % .SP
] bits_tmpl

(A^013^010^013^010^013^010^013^010^013^010) (parse debugbits) [  % Upper
    (00010)    % A
    (11101)    % M/L
    (11110)    % P/L
    (00010)    % CRLF
    (00010)    % CRLF
    (00010)    % CRLF
    (00010)    % CRLF
    (00010)    % CRLF
] bits_tmpl

(a. ) (debugbits) [          % Lower
    (11100)    % L/L
    (00010)    % a
    (00000)    % P/S
    (00011)    % .SP
] bits_tmpl

(a^013^010) (parse debugbits) [  % Lower
    (11100)    % L/L
    (00010)    % a
    (00000)    % P/S
    (00010)    % CRLF
] bits_tmpl

(a. . . . . ) (debugbits) [  % Lower
