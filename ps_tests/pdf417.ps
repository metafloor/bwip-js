%
% Error tests
%

% Input too long
12501 string (dontdraw) /bwipp.pdf417inputTooLong er_tmpl

% Long text input must not crash the text submode optimizer
/s 10000 string def 0 1 9999 { s exch 65 put } for
s (dontdraw) /bwipp.pdf417dataTooLong er_tmpl

% Empty data
() (dontdraw) /bwipp.pdf417emptyData er_tmpl

% Invalid rows (valid: 3-90)
(TEST) (rows=2 dontdraw) /bwipp.pdf417invalidRows er_tmpl
(TEST) (rows=91 dontdraw) /bwipp.pdf417invalidRows er_tmpl

% Invalid columns (valid: 1-30)
(TEST) (columns=-1 dontdraw) /bwipp.pdf417invalidColumns er_tmpl
(TEST) (columns=31 dontdraw) /bwipp.pdf417invalidColumns er_tmpl

% Invalid row multiplier
(TEST) (rowmult=0 dontdraw) /bwipp.pdf417badRowMult er_tmpl
(TEST) (rowmult=51 dontdraw) /bwipp.pdf417badRowMult er_tmpl

% Cannot combine ccc and raw
(TEST) (ccc raw dontdraw) /bwipp.pdf417cccAndRaw er_tmpl

% Cannot combine ccc and compact
(TEST) (ccc compact dontdraw) /bwipp.pdf417cccAndCompact er_tmpl

% Invalid raw format
(TEST) (raw parse dontdraw) /bwipp.pdf417badRawFormat er_tmpl
(^12A) (raw dontdraw) /bwipp.pdf417badRawFormat er_tmpl
(^12) (raw dontdraw) /bwipp.pdf417badRawFormat er_tmpl
(^1) (raw dontdraw) /bwipp.pdf417badRawFormat er_tmpl
(^) (raw dontdraw) /bwipp.pdf417badRawFormat er_tmpl

% Raw codeword out of range (valid: 0-928)
(^929) (raw dontdraw) /bwipp.pdf417badRawCodeword er_tmpl
(^999) (raw dontdraw) /bwipp.pdf417badRawCodeword er_tmpl

% ECI range (valid: 000000-811799)
{ (^ECI811799) (parsefnc dontdraw) pdf417 pop true } true isEqual
(^ECI811800) (parsefnc dontdraw) /bwipp.pdf417badECI er_tmpl
(^ECI900000) (parsefnc dontdraw) /bwipp.pdf417badECI er_tmpl

% Data too long (>926 codewords)
{ 2000 string 0 1 1999 { 1 index exch 65 put } for (dontdraw) pdf417 } /bwipp.pdf417dataTooLong isError

% Insufficient capacity
() (columns=1 dontdraw) /bwipp.pdf417insufficientCapacity er_tmpl

% Symbol length descriptor exceeds codeword range
(test) (rows=90 columns=30 dontdraw) /bwipp.pdf417insufficientCapacity er_tmpl

% Option edges: columns
{ (TEST) (columns=0 dontdraw) pdf417 pop true } true isEqual
(TEST) (columns=999 dontdraw) /bwipp.pdf417invalidColumns er_tmpl

% Option edges: rows
(TEST) (rows=-1 dontdraw) /bwipp.pdf417invalidRows er_tmpl
(TEST) (rows=999 dontdraw) /bwipp.pdf417invalidRows er_tmpl

% Option edges: eclevel
(TEST) (eclevel=9 dontdraw) /bwipp.pdf417InvalidErrorCorrectionLevel er_tmpl

% Option edges: columns and rows combined
{ (TEST) (columns=1 rows=3 dontdraw) pdf417 pop true } true isEqual

% Raw mode edge cases
{ (^928) (raw dontdraw) pdf417 pop true } true isEqual
{ (^000) (raw dontdraw) pdf417 pop true } true isEqual
{ (^928^000) (raw dontdraw) pdf417 pop true } true isEqual

% Parse mode edge cases
{ (^^) (parse dontdraw) pdf417 pop true } true isEqual
{ (^000) (parse dontdraw) pdf417 pop true } true isEqual
{ (^255) (parse dontdraw) pdf417 pop true } true isEqual
(^256) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
(^999) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
{ (^NUL) (parse dontdraw) pdf417 pop true } true isEqual
{ (A^) (parse dontdraw) pdf417 pop true } true isEqual
{ (^1) (parse dontdraw) pdf417 pop true } true isEqual
{ (^12) (parse dontdraw) pdf417 pop true } true isEqual

% parsefnc edge cases
(^FNC1) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC2) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC3) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC4) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
{ (^ECI000000) (parsefnc dontdraw) pdf417 pop true } true isEqual
(^ECI999999) (parsefnc dontdraw) /bwipp.pdf417badECI er_tmpl
(^ECI) (parsefnc dontdraw) /bwipp.truncatedECI er_tmpl
(^ECI1) (parsefnc dontdraw) /bwipp.truncatedECI er_tmpl
end
} bind def
