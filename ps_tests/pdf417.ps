/runtest_pdf417 {
20 dict begin
% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

% ISO/IEC 15438:2015


%%/pdf417 dup /uk.co.terryburton.bwipp findresource cvx def

/er_tmpl {
    3 1 roll { _arg0_ _arg1_ pdf417 }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def


% Check when text pad spans ECI(s)

{  % Alpha sub-mode ml pad ECI alpha sub-mode
    (ABCDE^ECI000017FGHIJ) (debugcws parse parsefnc) pdf417
} [10 1 63 148 927 17 845 187 249 900] debugIsEqual

{  % Alpha sub-mode ll pad ECI lower sub-mode
    (ABCDE^ECI000017fghij) (debugcws parse parsefnc) pdf417
} [10 1 63 147 927 17 156 218 299 900] debugIsEqual

{  % Alpha sub-mode ml pad ECI mixed sub-mode
    (ABCDE^ECI000017,:#-.) (debugcws parse parsefnc) pdf417
} [10 1 63 148 927 17 404 466 539 900] debugIsEqual

{  % Alpha sub-mode ml pad ECI punctuation sub-mode
    (ABCDE^ECI000017;<>@[) (debugcws parse parsefnc) pdf417
} [10 1 63 148 927 17 750 32 94 900] debugIsEqual

{  % Lower sub-mode ml pad ECI lower sub-mode
    (abcdef^ECI000017ghijk) (debugcws parse parsefnc) pdf417
} [10 810 32 94 178 927 17 816 218 280] debugIsEqual

{  % Lower sub-mode ml pad ECI mixed sub-mode
    (abcdef^ECI000017,:#-.$) (debugcws parse parsefnc) pdf417
} [10 810 32 94 178 927 17 404 466 528] debugIsEqual

{  % Mixed sub-mode ll pad ECI lower sub-mode
    (,:#-.$^ECI000017abcde) (debugcws parse parsefnc) pdf417
} [10 853 435 497 567 927 17 1 63 149] debugIsEqual

{  % Mixed sub-mode pl pad ECI punctuation sub-mode
    (,:#-.$^ECI000017;<>@[) (debugcws parse parsefnc) pdf417
} [10 853 435 497 565 927 17 1 63 149] debugIsEqual

{  % Mixed sub-mode al pad ECI alpha sub-mode
    (,:#-.$^ECI000017ABCDE) (debugcws parse parsefnc) pdf417
} [10 853 435 497 568 927 17 1 63 149] debugIsEqual

{  % Punctuation sub-mode al pad ECI alpha sub-mode
    (;<>@[^ECI000017ABCDE) (debugcws parse parsefnc) pdf417
} [10 865 1 63 149 927 17 1 63 149] debugIsEqual

{  % Alpha sub-mode ps pad ECI numeric mode mixed sub-mode (no change)
    (ABCDE^ECI000017123456789012345,:#-.) (debugcws parse parsefnc) pdf417
} [19 1 63 149 927 17 902 1 812 292 890 124 745 900 853 435 497 900 900] debugIsEqual

{  % Alpha sub-mode ps pad ECI byte mode mixed sub-mode (no change)
    (ABCDE^ECI000017^160^161^162,:#-.) (debugcws parse parsefnc) pdf417
} [16 1 63 149 927 17 901 160 161 162 900 853 435 497 900 900] debugIsEqual

{  % Alpha sub-mode ml pad ECIs alpha sub-mode
    (ABCDE^ECI000017^ECI000004FGHIJ) (debugcws parse parsefnc) pdf417
} [12 1 63 148 927 17 927 4 845 187 249 900] debugIsEqual

{  % Lower sub-mode ml pad ECIs mixed sub-mode al pad ECI alpha sub-mode
    (abcdef^ECI000017^ECI000004,:#-.^ECI000005FGHIJ) (debugcws parse parsefnc) pdf417
} [19 810 32 94 178 927 17 927 4 404 466 538 927 5 156 218 299 900 900] debugIsEqual


%
% Text compaction submodes
%

% Alpha submode: single char
{ (A) (debugcws) pdf417 } [
    4       % symbol length
    913 65  % byte-shift 'A'
    900     % PAD (text latch)
] debugIsEqual

% Alpha submode: HELLO
{ (HELLO) (debugcws) pdf417 } [
    4            % symbol length
    214 341 449  % HELLO (text alpha)
] debugIsEqual

% Lower submode: hello
{ (hello) (debugcws) pdf417 } [
    4            % symbol length
    817 131 344  % hello (text lower)
] debugIsEqual

% Mixed submode: digits
{ (0123456789) (debugcws) pdf417 } [
    6              % symbol length
    902            % numeric latch
    13 798 85 289  % 0123456789 (numeric compaction)
] debugIsEqual

% Punctuation submode: semicolons
{ (;;) (debugcws) pdf417 } [
    4          % symbol length
    901 59 59  % ;; (text punct via byte)
] debugIsEqual


%
% Text mode transitions
%

% Alpha to Lower
{ (ABCabc) (debugcws) pdf417 } [
    6          % symbol length
    1 87       % ABC (alpha)
    1 89       % abc (lower)
    900        % PAD (text latch)
] debugIsEqual

% Lower to Alpha
{ (abcABC) (debugcws) pdf417 } [
    6           % symbol length
    810 32 868  % abc (lower)
    1 89        % ABC (alpha)
] debugIsEqual

% Alpha to Mixed
{ (ABC123) (debugcws) pdf417 } [
    6          % symbol length
    1 88       % ABC (alpha)
    32 119     % 123 (mixed)
    900        % PAD (text latch)
] debugIsEqual

% Mixed to Alpha
{ (123ABC) (debugcws) pdf417 } [
    6           % symbol length
    841 63 840  % 123 (mixed)
    32          % ABC (alpha, partial)
    900         % PAD (text latch)
] debugIsEqual


%
% Numeric compaction
%

% Numeric compaction for all-numeric input with length >= 8
{
    (12345678) (debugcws) pdf417
} [6          % symbol length
  902         % numeric latch
  138 628 478  % 12345678 (numeric compaction)
  900         % PAD (text latch)
] debugIsEqual

{  % 13 digits
    (1234567890123) (debugcws) pdf417
} [8          % symbol length
  902         % numeric latch
  17 110 836 811 223  % 1234567890123 (numeric compaction)
  900         % PAD (text latch)
] debugIsEqual

{  % 44 digits (full group)
    (11111111111111111111111111111111111111111111) (debugcws) pdf417
} [19         % symbol length
  902         % numeric latch
  485 624 195 647 193 431 299 2 752 141 640 160 581 556 711  % 44 digits (numeric)
  900 900     % PAD PAD
] debugIsEqual

{  % 50 digits exercises multiple iterations of numeric encoding outer loop
    (12345678901234567890123456789012345678901234567890) (debugcws) pdf417
} [22         % symbol length
  902         % numeric latch
  491 81 137 450 302 67 15 174 492 862 667 475 869 12 434 1 842 90  % 50 digits (numeric)
  900 900     % PAD PAD
] debugIsEqual

%
% Byte compaction
%

/bdata6 6 string def 0 1 5 {bdata6 exch 128 put} for
{  % 6 bytes (exact group)
    bdata6 (debugcws) pdf417
} [8          % symbol length
  924         % byte latch (6n compaction)
  215 312 558 104 768  % 6x 0x80 (byte compaction)
  900         % PAD (text latch)
] debugIsEqual

/bdata1 1 string def bdata1 0 128 put
{  % 1 byte (shift to byte)
    bdata1 (debugcws) pdf417
} [4          % symbol length
  913 128     % byte-shift 0x80
  900         % PAD (text latch)
] debugIsEqual


%
% Mixed text then bytes
%

/mdata 8 string def
mdata 0 65 put mdata 1 66 put mdata 2 67 put
3 1 7 {mdata exch 200 put} for
{  % Text followed by byte data
    mdata (debugcws) pdf417
} [10         % symbol length
  901         % byte latch
  109 326 378 776 648  % ABC (text-encoded as bytes)
  200 200     % 0xC8 0xC8 (raw bytes)
  900         % PAD (text latch)
] debugIsEqual


%
% Fixed EC levels
%

{  % Fixed eclevel 0: 2 ECC codewords
    (Hello) (fixedeclevel eclevel=0 debugcws) pdf417
} [4          % symbol length
  237 131 344  % Hello (text alpha+lower)
] debugIsEqual

{  % Fixed eclevel 0: 2 ECC codewords
    (Hello) (fixedeclevel eclevel=0 debugecc) pdf417
} [312 132    % ECC (2 codewords)
] debugIsEqual

{  % Fixed eclevel 1: 4 ECC codewords
    (Hello) (fixedeclevel eclevel=1 debugcws) pdf417
} [4          % symbol length
  237 131 344  % Hello (text alpha+lower)
] debugIsEqual

{  % Fixed eclevel 1: 4 ECC codewords
    (Hello) (fixedeclevel eclevel=1 debugecc) pdf417
} [844 635 466 149  % ECC (4 codewords)
] debugIsEqual


%
% Column options
%

{  % 1 column
    (Hello World) (columns=1 debugcws) pdf417
} [8          % symbol length
  237 131 344 807 674 521 119  % Hello World (text)
] debugIsEqual

{  % 5 columns (with padding)
    (Hello World) (columns=5 debugcws) pdf417
} [12         % symbol length
  237 131 344 807 674 521 119  % Hello World (text)
  900 900 900 900  % PAD PAD PAD PAD
] debugIsEqual


%
% Compact mode
%

{  % Compact
    (Hello World) (compact debugcws) pdf417
} [8          % symbol length
  237 131 344 807 674 521 119  % Hello World (text)
] debugIsEqual


%
% Raw mode
%

{  % Raw codewords
    (^001^002^003) (raw debugcws) pdf417
} [4          % symbol length
  1 2 3       % raw codewords
] debugIsEqual


%
% ECI
%

{  % ECI 3 (Latin-1)
    (^ECI000003Hello) (parsefnc debugcws) pdf417
} [6          % symbol length
  927 3       % ECI 3
  237 131 344  % Hello (text)
] debugIsEqual

{  % ECI 900 (two-codeword)
    (^ECI000900Hello) (parsefnc debugcws) pdf417
} [8          % symbol length
  926 0 0     % ECI 900 (two-codeword form)
  237 131 344  % Hello (text)
  900         % PAD (text latch)
] debugIsEqual

{  % ECI 811799 (max, one-codeword)
    (^ECI811799Hello) (parsefnc debugcws) pdf417
} [6          % symbol length
  925 899     % ECI 811799 (one-codeword form: 811799-810900=899)
  237 131 344  % Hello (text)
] debugIsEqual


%
% Parse mode
%

{  % Parse NUL byte
    (^000) (parse debugcws) pdf417
} [4          % symbol length
  913 0       % byte-shift 0x00
  900         % PAD (text latch)
] debugIsEqual


% eclevel validation

{  % eclevel 0: 2 ECC codewords
    (12345678) (debugcws eclevel=0) pdf417
} [5          % symbol length
  902         % numeric latch
  138 628 478  % 12345678 (numeric)
] debugIsEqual

{  % eclevel 0: 2 ECC codewords
    (12345678) (debugecc eclevel=0) pdf417
} [88 873     % ECC (2 codewords)
] debugIsEqual

{  % eclevel 8: 512 ECC codewords
    (12345678) (debugcws eclevel=8) pdf417
} [8          % symbol length
  902         % numeric latch
  138 628 478  % 12345678 (numeric)
  900 900 900  % PAD PAD PAD
] debugIsEqual

{
    (12345678) (debugcws eclevel=9) pdf417
} /bwipp.pdf417InvalidErrorCorrectionLevel isError

{  % Defaults to eclevel 2: 8 ECC codewords
    (12345678) (debugcws eclevel=-1) pdf417
} [6          % symbol length
  902         % numeric latch
  138 628 478  % 12345678 (numeric)
  900         % PAD (text latch)
] debugIsEqual

{
    (12345678) (debugcws eclevel=-2) pdf417
} /bwipp.pdf417InvalidErrorCorrectionLevel isError


% Example

(PDF417 Symbology Standard) (dontdraw eclevel=1 columns=2) pdf417 /pixs get  % ISO/IEC 15438:2015 Figure 1, not same, slightly different encodation (figure "<SP> al S ll" instead of "ll <SP> as S")
[
