((01)90012) (dontdraw dontlint) databarexpanded pop

% Short/empty weight and date values with dontlint fall through
((01)90012345678908(3103)) (dontdraw dontlint) databarexpanded pop
((01)90012345678908(3202)) (dontdraw dontlint) databarexpanded pop
((01)90012345678908(3103)001234(15)) (dontdraw dontlint) databarexpanded pop
((01)90012345678908(3103)001234(15)1) (dontdraw dontlint) databarexpanded pop
