20 dict begin
% Barcode Writer in Pure PostScript
% https://bwipp.terryburton.co.uk
%
% vim: set sw=4 sts=4 et:
%
% Copyright (c) 2004-2026 Terry Burton
%

% ISO/IEC 24724:2011


%%/databarexpanded dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    exch { _arg0_ (dontdraw) databarexpanded /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def

/eq_tmpl_dontlint {
    exch { _arg0_ (dontdraw dontlint) databarexpanded /sbs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def

/eq_tmpl_bits {
    exch { _arg0_ (debugbits dontlint) databarexpanded } dup 3 -1 roll 0 exch put
    exch debugIsEqual
} def


((01)00012345678905(10)ABC123)  % Encoding method "1" (24724:2011 7.2.5.4.1)
    [1 3 2 5 1 1 2 1 2 1 8 4 1 1 2 2 2 4 1 1 4 1 1 1 4 2 2 1 5 1 1 1 5 6 2 3 1 1 2 4 2 1 3 3 4 1 2 1 1 1 4 3 6 4 1 1 3 3 2 2 1 4 1 1 1 2 3 1 6 1 2 1 1 1 8 2 3 2 1 1 2 1 6 1 3 2 2 1 3 2 1 1 5 3 4 6 1 1 1 1]
    eq_tmpl
