%
% Error tests
%

% Input too long
5001 string (dontdraw) /bwipp.micropdf417inputTooLong er_tmpl

% Long text input must not crash the text submode optimizer
/s 5000 string def 0 1 4999 { s exch 65 put } for
s (dontdraw) /bwipp.micropdf417noValidSymbol er_tmpl

% Empty data
() (dontdraw) /bwipp.micropdf417emptyData er_tmpl

% Invalid row multiplier (valid: > 0 and <= 50)
(TEST) (rowmult=0 dontdraw) /bwipp.micropdf417badRowMult er_tmpl
(TEST) (rowmult=51 dontdraw) /bwipp.micropdf417badRowMult er_tmpl

% Cannot combine cca, ccb and raw
(TEST) (cca raw dontdraw) /bwipp.micropdf417ccaAndCcb er_tmpl
(TEST) (ccb raw dontdraw) /bwipp.micropdf417ccaAndCcb er_tmpl

% Invalid version format
(TEST) (version=X dontdraw) /bwipp.micropdf417badVersionFormat er_tmpl

% Invalid version rows/columns (non-digit in row or column)
(TEST) (version=Ax1 dontdraw) /bwipp.micropdf417BadVersionBadRowOrColumn er_tmpl

% Invalid cca/raw format
(TEST) (raw dontdraw) /bwipp.micropdf417badCcaRawFormat er_tmpl
(^12A) (raw dontdraw) /bwipp.micropdf417badCcaRawFormat er_tmpl
(^12) (raw dontdraw) /bwipp.micropdf417badCcaRawFormat er_tmpl
(^1) (raw dontdraw) /bwipp.micropdf417badCcaRawFormat er_tmpl
(^) (raw dontdraw) /bwipp.micropdf417badCcaRawFormat er_tmpl

% Raw codeword out of range (valid: 0-928)
(^929) (raw dontdraw) /bwipp.micropdf417badRawCodeword er_tmpl
(^999) (raw dontdraw) /bwipp.micropdf417badRawCodeword er_tmpl

% Data too long
{ 400 string 0 1 399 { 1 index exch 65 put } for (dontdraw) micropdf417 } /bwipp.micropdf417noValidSymbol isError

% Option edges: version
(TEST) (version=-1 dontdraw) /bwipp.micropdf417badVersionFormat er_tmpl
(TEST) (version=0 dontdraw) /bwipp.micropdf417badVersionFormat er_tmpl
(TEST) (version=35 dontdraw) /bwipp.micropdf417badVersionFormat er_tmpl

% Option edges: columns
{ (TEST) (columns=0 dontdraw) micropdf417 pop true } true isEqual
(TEST) (columns=5 dontdraw) /bwipp.micropdf417noValidSymbol er_tmpl

% Raw mode edge cases
{ (^928) (raw dontdraw) micropdf417 pop true } true isEqual
{ (^000) (raw dontdraw) micropdf417 pop true } true isEqual
{ (^928^000) (raw dontdraw) micropdf417 pop true } true isEqual

% Parse mode edge cases
(^256) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
(^999) (parse dontdraw) /bwipp.invalidOrdinal er_tmpl
{ (^^) (parse dontdraw) micropdf417 pop true } true isEqual
{ (^000) (parse dontdraw) micropdf417 pop true } true isEqual
{ (^255) (parse dontdraw) micropdf417 pop true } true isEqual
{ (^NUL) (parse dontdraw) micropdf417 pop true } true isEqual
{ (A^) (parse dontdraw) micropdf417 pop true } true isEqual
{ (^1) (parse dontdraw) micropdf417 pop true } true isEqual
{ (^12) (parse dontdraw) micropdf417 pop true } true isEqual

% parsefnc edge cases
(^FNC1) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC2) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC3) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
(^FNC4) (parsefnc dontdraw) /bwipp.unknownFNC er_tmpl
{ (^ECI000000) (parsefnc dontdraw) micropdf417 pop true } true isEqual
{ (^ECI811799) (parsefnc dontdraw) micropdf417 pop true } true isEqual
(^ECI811800) (parsefnc dontdraw) /bwipp.pdf417badECI er_tmpl
(^ECI999999) (parsefnc dontdraw) /bwipp.pdf417badECI er_tmpl
(^ECI) (parsefnc dontdraw) /bwipp.truncatedECI er_tmpl
(^ECI1) (parsefnc dontdraw) /bwipp.truncatedECI er_tmpl
end
