%%/codablockf dup /uk.co.terryburton.bwipp findresource cvx def

/eq_tmpl {
    exch { _arg0_ (dontdraw parse) codablockf /pixs get } dup 3 -1 roll 0 exch put
    exch isEqual
} def

/er_tmpl {
    3 1 roll { _arg0_ _arg1_ codablockf }
    dup 3 -1 roll 1 exch put
    dup 3 -1 roll 0 exch put
    exch isError
} def


