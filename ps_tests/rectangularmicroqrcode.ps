% A7 B8
(K9K9K9K^000^000^000^000^000^000^000^000) (parse version=R11x59 eclevel=H fixedeclevel debugbitseqs) 19 [
    (010)            % A mode
    (000111)         % Char count: 7
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (010100)         % K: 20
    (011)            % B mode
    (01000)          % Char count: 8
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
