%
% Error tests
%

% Empty data
() (dontdraw) /bwipp.qrcodeEmptyData er_tmpl

% Version required for RMQR
() (version=R7x43 dontdraw) /bwipp.qrcodeEmptyData er_tmpl

% Invalid version
(TEST) (version=R0x0 dontdraw) /bwipp.qrcodeInvalidRMQRversion er_tmpl

% Mask not allowed for RMQR
(TEST) (version=R7x43 mask=0 dontdraw) /bwipp.qrcodeRMQRmask er_tmpl

% Version required for RMQR (via qrcode with format=rmqr)
(TEST) (format=rmqr dontdraw) /bwipp.qrcodeRMQRwithoutVersion er_tmpl

(TEST) (version=R7x42 dontdraw) /bwipp.qrcodeInvalidRMQRversion er_tmpl
(TEST) (version=R99x99 dontdraw) /bwipp.qrcodeInvalidRMQRversion er_tmpl
(TEST) (version=R7x43 eclevel=Q dontdraw) /bwipp.qrcodeNoValidSymbol er_tmpl
end
} bind def
