] bitseqs_tmpl

% A10 B6
(K9K9K9K9K9^000^000^000^000^000^000) (parse version=R11x59 eclevel=H fixedeclevel debugbitseqs) 19 [
    (010)            % A mode
    (001010)         % Char count: 10
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (01110001101)    % K9: 20*45+9 = 909
    (011)            % B mode
    (00110)          % Char count: 6
    (00000000)       % 0x00
