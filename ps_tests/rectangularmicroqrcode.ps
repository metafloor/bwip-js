% Table 6 R7x43-M max 7 alphanumeric (cclen bits 4 -> 3)
(ABCDEFG) (version=R7x43 fixedeclevel debugbitseqs) 7 [
    (010)            % A mode
    (111)            % Char count: 7
    (00111001101)    % AB: 10*45+11 = 461
    (01000101001)    % CD: 12*45+13 = 553
    (01010000101)    % EF: 14*45+15 = 645
    (010000)         % G: 16
] bitseqs_tmpl

