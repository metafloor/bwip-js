    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (01001011)       % 0x4B 'K'
    (010)            % A mode
    (001000)         % Char count: 8
    (00110101001)    % 9K: 9*45+20 = 425
    (00110101001)    % 9K: 9*45+20 = 425
    (00110101001)    % 9K: 9*45+20 = 425
    (00110101001)    % 9K: 9*45+20 = 425
] bitseqs_tmpl
} if


