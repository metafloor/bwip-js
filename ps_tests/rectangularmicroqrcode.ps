% Encodation examples

% 7.4.2.2 ECI Example, R17x139-H (using M) same codewords
(^ECI000009^161^162^163^164^165) (parse parsefnc version=R17x139 eclevel=M fixedeclevel debugbitseqs) 38 [
    (111)            % E mode
    (00001001)       % ECI 9
    (011)            % B mode
    (00000101)       % Char count: 5
    (10100001)       % 0xA1 (161)
    (10100010)       % 0xA2 (162)
    (10100011)       % 0xA3 (163)
    (10100100)       % 0xA4 (164)
    (10100101)       % 0xA5 (165)
] bitseqs_tmpl

% 7.4.3 Numeric mode Example, R7x59-M, same codewords
(0123456789012345) (version=R7x59 fixedeclevel debugbitseqs) 8 [
    (001)            % N mode
    (10000)          % Char count: 16
    (0000001100)     % 012
    (0101011001)     % 345
    (1010100110)     % 678
    (1110000101)     % 901
    (0011101010)     % 234
    (0101)           % 5
] bitseqs_tmpl

% 7.4.4 Alphanumeric mode Example, R7x59-H, same codewords
(AC-42) (version=R7x59 eclevel=H fixedeclevel debugbitseqs) 8 [
    (010)            % A mode
    (00101)          % Char count: 5
    (00111001110)    % AC: 10*45+12 = 462
    (11100111001)    % -4: 41*45+4 = 1849
    (000010)         % 2: 2
] bitseqs_tmpl

% 7.4.5 Byte mode, R7x43-M, 5 bytes max (Table 6)
(?????) (version=R7x43 eclevel=M fixedeclevel debugbitseqs) 7 [
    (011)         % B mode
    (101)         % Char count: 5
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
    (00111111)    % 0x3F '?'
] bitseqs_tmpl

% 7.4.6 Kanji mode (点茗点), R7x43-M, 3 Kanji max (Table 6)
(^147^095^228^170^147^095) (parse version=R7x43 eclevel=M fixedeclevel debugbitseqs) 7 [
    (100)              % K mode
    (11)               % Char count: 3
    (0110110011111)    % 点: Kanji 3487
    (1101010101010)    % 茗: Kanji 6826
    (0110110011111)    % 点: Kanji 3487
] bitseqs_tmpl

% B14, issue #237, previously unencodable A2 B12
(K9^000^000^000^000^000^000^000^000^000^000^000^000) (parse version=R11x59 eclevel=H fixedeclevel debugbitseqs) 19 [
    (011)         % B mode
    (01110)       % Char count: 14
    (01001011)    % 0x4B 'K'
    (00111001)    % 0x39 '9'
    (00000000)    % 0x00
    (00000000)    % 0x00
    (00000000)    % 0x00
