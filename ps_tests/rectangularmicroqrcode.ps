    (01001000)    % 0x48 'H'
    (01100101)    % 0x65 'e'
    (01101100)    % 0x6C 'l'
    (01101100)    % 0x6C 'l'
    (01101111)    % 0x6F 'o'
] bitseqs_tmpl

% R7x43 N5: 12345
(12345) (version=R7x43 fixedeclevel debugbitseqs) 7 [
    (001)            % N mode
    (0101)           % Char count: 5
    (0001111011)     % 123
    (0101101)        % 45
] bitseqs_tmpl


