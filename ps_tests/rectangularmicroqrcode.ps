    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (00000000)       % 0x00
    (010)            % A mode
